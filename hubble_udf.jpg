				<figure class="hds-media-background  "><video class="hds-video-background " alt="" style="transform: scale(1); transform-origin: 50% 50%; object-position: 50% 50%; object-fit: cover;" autoplay="true" loop muted="true" playsinline="true" preload="metadata"><source src="https://assets.science.nasa.gov/content/dam/science/missions/hubble/videos/Hubble%20Header%20720.mp4" type="video/mp4" /></video></figure>			</div>
