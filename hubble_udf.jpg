<style id='nasa-blocks-card-carousel-style-inline-css'>
.hds-card-carousel .hds-carousel-nav-arrow{align-items:center;background:#fff;border:1px solid #b9b9bb;border-radius:50%;box-sizing:border-box;display:flex;height:40px;justify-content:center;margin-right:8px;transition:all .2s ease;width:40px}.hds-card-carousel .hds-carousel-nav-arrow:hover{border:1px solid #000}.hds-card-carousel .hds-carousel-nav{left:0;position:absolute;top:50%;width:100%;z-index:10}.hds-card-carousel .hds-carousel-nav-arrow{margin:0;position:absolute;top:50%;z-index:500}.hds-card-carousel .hds-carousel-nav-arrow:hover{cursor:pointer}.hds-card-carousel .hds-carousel-arrow-prev{left:-10px;right:unset}.hds-card-carousel .hds-carousel-arrow-next{left:unset;right:-10px}.hds-card-carousel .hds-card-grid-header{padding-left:30px;padding-right:30px}.hds-card-carousel .hds-card-grid-cards{padding-left:20px;padding-right:20px}.hds-card .hds-card-inner{display:block;margin-left:auto;margin-right:auto;position:relative;width:calc(100% - 20px)}.hds-card-carousel .hds-card-carousel-header{padding-left:10px;padding-right:10px}.hds-card .hds-card-content{width:100%}.hds-card-hover-zoom-image .hds-media-background{transition:transform .3s ease-in-out}.hds-card:hover .hds-card-hover-zoom-image .hds-media-background{transform:scale(1.05)}.hds-card .hds-card-thumbnail{display:block;overflow:hidden;padding:0;position:relative}.hds-card .hds-card-thumbnail:after{content:"";display:block;padding-bottom:56.25%}.hds-card-custom .hds-card-thumbnail:after{padding-bottom:75%}.hds-card-article-default .hds-card-thumbnail:after{padding-bottom:67%}.hds-card-article-graphical .hds-card-thumbnail:after{padding-bottom:140%}.hds-card-subtopic .hds-card-thumbnail:after,.hds-card-topic .hds-card-thumbnail:after{padding-bottom:150%}.hds-card-location .hds-card-thumbnail:after{padding-bottom:75%}.hds-card-gallery .hds-card-gallery-images{display:grid;gap:.25rem;grid-template-columns:1.75fr 1fr;grid-template-rows:1fr 1fr}.hds-card-gallery .hds-card-gallery-images .hds-media-background